# ============================================================
# APTRG Open Recruitment Portal — Environment Variables
# Salin file ini menjadi .env.local dan isi dengan nilai asli.
# JANGAN commit .env.local ke repository!
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Dapatkan dari: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── REST API Backend ──────────────────────────────────────
# Base URL untuk endpoint internal (pengumuman, admin, dll.)
# Contoh lokal: http://localhost:3001
# Contoh production: https://api.aptrg.lab/v1
VITE_API_BASE_URL=http://localhost:3001
